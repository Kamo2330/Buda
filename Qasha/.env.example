# Copy to .env and adjust.
#
# SQLite (no Docker): USE_POSTGRES=false
# PostgreSQL with Docker: docker compose up -d, then USE_POSTGRES=true (default below)
# Hosted Postgres: set DATABASE_URL instead of individual POSTGRES_* vars

USE_POSTGRES=true

DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost
# When DEBUG=true, your LAN IP (e.g. 192.168.x.x) is added automatically for phone testing.
TIME_ZONE=Africa/Johannesburg

# Generate before production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

POSTGRES_DB=qasha
POSTGRES_USER=qasha
POSTGRES_PASSWORD=qasha
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: single URL (overrides POSTGRES_* when set)
# DATABASE_URL=postgresql://qasha:qasha@localhost:5432/qasha

DB_CONN_MAX_AGE=60

# Optional: email for urgent Help alerts (defaults to Site configuration contact email)
# HELP_ALERT_EMAIL=you@yourdomain.co.za

# Google Maps — enable Places API + Maps JavaScript API, then:
# GOOGLE_MAPS_API_KEY=your_key_here
# ALLOWED_HOSTS=yourdomain.co.za,www.yourdomain.co.za
# CSRF_TRUSTED_ORIGINS=https://yourdomain.co.za,https://www.yourdomain.co.za
